  "form": {
    "endpoint": "https://formsubmit.co/amworxx@gmail.com",
    "ownerEmail": "amworxx@gmail.com",
    "redirectTo": "thanks.html",
    "showEstimate": true,
    "sections": [
      { "id": "basics", "label": "Business basics" },
      { "id": "content", "label": "Pages & content" },
      { "id": "features", "label": "Features" },
      { "id": "hosting", "label": "Hosting & launch" },
      { "id": "budget", "label": "Budget & contact" }
    ],
    "fields": {
      "business_name": { "type": "text", "label": "Business name", "required": true, "section": "basics" },
      "industry": { "type": "text", "label": "Industry / niche", "required": false, "section": "basics" },
      "is_new": { "type": "select", "label": "Is this a new business?", "options": ["Yes, brand new", "Existing business rebrand", "Existing, just adding a site"], "section": "basics" },
      "has_site": { "type": "select", "label": "Do you already have a website?", "options": ["No", "Yes — url"], "section": "basics" },
      "site_url": { "type": "url", "label": "Current website URL", "required": false, "showIf": { "field": "has_site", "equals": "Yes — url" }, "section": "basics" },
      "site_type": { "type": "select", "label": "Site type", "options": ["Business / portfolio", "Blog / magazine", "E-commerce", "Membership / courses", "Other"], "section": "content" },
      "pages_estimate": { "type": "select", "label": "Rough page count", "options": ["1–2", "3–5", "6–10", "11–20", "20+"], "section": "content" },
      "needs_copy": { "type": "select", "label": "Written content (copywriting)", "options": ["I'll provide everything", "Help me with tone & structure", "Write it all for me"], "section": "content" },
      "needs_photos": { "type": "select", "label": "Photos / images", "options": ["I'll provide all", "Mix — I have some + I need some", "Source everything for me"], "section": "content" },
      "needs_logo": { "type": "select", "label": "Logo", "options": ["I have one", "Redesign / update", "I need a new one"], "section": "content" },
      "features": {
        "type": "checkbox",
        "label": "Which features do you need?",
        "options": [
          { "value": "contact_form", "label": "Contact form" },
          { "value": "portfolio_gallery", "label": "Portfolio / project gallery" },
          { "value": "services_pricing", "label": "Services / pricing" },
          { "value": "testimonials", "label": "Testimonials" },
          { "value": "blog", "label": "Blog / news section" },
          { "value": "newsletter", "label": "Newsletter signup" },
          { "value": "social_feeds", "label": "Social media feeds" },
          { "value": "multilang", "label": "Multi-language" },
          { "value": "booking", "label": "Booking / scheduling" },
          { "value": "live_chat", "label": "Live chat" },
          { "value": "membership", "label": "Membership login" }
        ],
        "section": "features"
      },
      "multilang_count": { "type": "number", "label": "Number of extra languages (besides English)", "required": false, "showIf": { "field": "features", "contains": "multilang" }, "section": "features", "min": 1, "max": 3, "default": 1 },
      "addons": {
        "type": "checkbox",
        "label": "Add-ons",
        "options": [
          { "value": "logo_design", "label": "Logo design" },
          { "value": "copywriting", "label": "Professional copywriting" },
          { "value": "photo_sourcing", "label": "Photo sourcing" },
          { "value": "seo_setup", "label": "SEO setup" },
          { "value": "speed_optimization", "label": "Speed optimization" }
        ],
        "section": "features"
      },
      "monthly_maintenance_months": { "type": "number", "label": "How many months of maintenance would you like?", "required": false, "showIf": { "field": "addons", "contains": "maintenance_monthly" }, "section": "features", "min": 1, "max": 12, "default": 1 },
      "visitors_estimate": { "type": "select", "label": "Expected monthly visitors", "options": ["Under 10,000", "10,000 – 100,000", "100,000+"], "section": "hosting" },
      "emails_needed": { "type": "number", "label": "Number of email accounts", "required": false, "default": 1, "min": 0, "section": "hosting" },
      "has_domain": { "type": "select", "label": "Domain", "options": ["I already own one", "I need to register a new domain (e.g. .com)", "Not sure yet"], "section": "hosting" },
      "launch_date": { "type": "text", "label": "Target launch date", "required": false, "section": "hosting", "placeholder": "e.g. September 2026" },
      "budget_range": { "type": "select", "label": "Budget range", "options": ["Under $1,500", "$1,500 – $3,000", "$3,000 – $6,000", "$6,000+"], "section": "budget" },
      "reference_sites": { "type": "textarea", "label": "Links to sites you like (up to 3)", "required": false, "section": "budget" },
      "client_name": { "type": "text", "label": "Your full name", "required": true, "section": "budget" },
      "client_email": { "type": "email", "label": "Your email", "required": true, "section": "budget" },
      "client_phone": { "type": "tel", "label": "Phone number", "required": false, "section": "budget" },
      "contact_pref": { "type": "select", "label": "Best way to contact you", "options": ["Email", "Phone", "WhatsApp"], "section": "budget" }
    }
  }
